---
/**
 * Booking widget component — embeds Cal.com or Calendly scheduling.
 *
 * Generated by /anglesite:booking. The skill populates the props from
 * the owner's configuration and injects this component into the
 * appropriate page or layout.
 */
interface Props {
  provider: 'cal' | 'calendly';
  username: string;
  eventSlug?: string;
  style: 'inline' | 'floating' | 'button';
  buttonText?: string;
  brandColor?: string;
}
const {
  provider,
  username,
  eventSlug,
  style,
  buttonText = "Book Now",
  brandColor = "#000000",
} = Astro.props;

const calLink = eventSlug ? `${username}/${eventSlug}` : username;
const colorHex = brandColor.replace(/^#/, "");
const calendlyUrl = eventSlug
  ? `https://calendly.com/${username}/${eventSlug}?primary_color=${colorHex}`
  : `https://calendly.com/${username}?primary_color=${colorHex}`;
---

{/* ── Cal.com ── */}

{provider === "cal" && style === "inline" && (
  <div id="booking-cal"></div>
  <script is:inline define:vars={{ calLink, colorHex }}>
    (function(C,A,L){let p=function(a,ar){a.q.push(ar)};let d=C.document;C.Cal=C.Cal||function(){let cal=C.Cal;let ar=arguments;if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true}if(ar[0]===L){const api=function(){p(api,arguments)};const namespace=ar[1];api.q=api.q||[];typeof namespace==="string"?(cal.ns[namespace]=api)&&p(api,ar):p(cal,ar);return}p(cal,ar)}})(window,"https://app.cal.com/embed/embed.js","init");
    Cal("init",{origin:"https://cal.com"});
    Cal("inline",{elementOrSelector:"#booking-cal",calLink:calLink,config:{theme:"auto",brandColor:colorHex}});
  </script>
)}

{provider === "cal" && style === "floating" && (
  <script is:inline define:vars={{ calLink, colorHex, buttonText }}>
    (function(C,A,L){let p=function(a,ar){a.q.push(ar)};let d=C.document;C.Cal=C.Cal||function(){let cal=C.Cal;let ar=arguments;if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true}if(ar[0]===L){const api=function(){p(api,arguments)};const namespace=ar[1];api.q=api.q||[];typeof namespace==="string"?(cal.ns[namespace]=api)&&p(api,ar):p(cal,ar);return}p(cal,ar)}})(window,"https://app.cal.com/embed/embed.js","init");
    Cal("init",{origin:"https://cal.com"});
    Cal("floatingButton",{calLink:calLink,buttonText:buttonText,config:{theme:"auto",brandColor:colorHex}});
  </script>
)}

{provider === "cal" && style === "button" && (
  <button class="booking-button" data-cal-link={calLink}>{buttonText}</button>
  <script is:inline define:vars={{ calLink, colorHex }}>
    (function(C,A,L){let p=function(a,ar){a.q.push(ar)};let d=C.document;C.Cal=C.Cal||function(){let cal=C.Cal;let ar=arguments;if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true}if(ar[0]===L){const api=function(){p(api,arguments)};const namespace=ar[1];api.q=api.q||[];typeof namespace==="string"?(cal.ns[namespace]=api)&&p(api,ar):p(cal,ar);return}p(cal,ar)}})(window,"https://app.cal.com/embed/embed.js","init");
    Cal("init",{origin:"https://cal.com"});
    Cal("pop",{calLink:calLink,config:{theme:"auto",brandColor:colorHex}});
  </script>
)}

{/* ── Calendly ── */}

{provider === "calendly" && style === "inline" && (
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
  <div class="calendly-inline-widget" data-url={calendlyUrl} style="min-width:320px;height:700px;"></div>
  <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
)}

{provider === "calendly" && style === "floating" && (
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
  <script is:inline define:vars={{ calendlyUrl, buttonText, brandColor: `#${colorHex}` }}>
    window.onload=function(){Calendly.initBadgeWidget({url:calendlyUrl,text:buttonText,color:brandColor,textColor:'#ffffff'})};
  </script>
  <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
)}

{provider === "calendly" && style === "button" && (
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
  <button class="booking-button" id="booking-calendly-btn">{buttonText}</button>
  <script is:inline define:vars={{ calendlyUrl }}>
    document.getElementById('booking-calendly-btn').addEventListener('click', function(e) {
      e.preventDefault();
      Calendly.initPopupWidget({url: calendlyUrl});
    });
  </script>
  <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
)}

<style>
  .booking-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-primary, #2563eb);
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }
  .booking-button:hover {
    opacity: 0.9;
  }
  .booking-button:focus-visible {
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }
</style>
