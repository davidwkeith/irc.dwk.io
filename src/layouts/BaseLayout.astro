---
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, image, jsonLd } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Auto-resolve OG image: custom image > per-page generated > site-wide default
function resolveOgImage(pathname: string, customImage?: string): string {
  if (customImage) return customImage;
  const slug = pathname.replace(/^\/+|\/+$/g, "") || "index";
  // Per-page OG image generated by npm run ai-og
  const perPage = `/images/og/${slug}.png`;
  // Fall back to site-wide default from npm run ai-images
  return perPage;
}
const ogImagePath = resolveOgImage(Astro.url.pathname, image);
const ogImage = new URL(ogImagePath, Astro.site).toString();

// Build generator string: Anglesite 0.16.4 (Claude Opus 4.6, Astro v5.16.0)
const { version } = JSON.parse(
  readFileSync(resolve(process.cwd(), "package.json"), "utf-8"),
);
const configPath = resolve(process.cwd(), ".site-config");
const configContent = existsSync(configPath)
  ? readFileSync(configPath, "utf-8")
  : "";
const aiModel =
  configContent.match(/^AI_MODEL=(.+)$/m)?.[1]?.trim() ?? "Claude";
const siteName =
  configContent.match(/^SITE_NAME=(.+)$/m)?.[1]?.trim() ?? "My Website";
const generator = `Anglesite ${version} (${aiModel}, ${Astro.generator})`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Feed -->
    <link rel="alternate" type="application/rss+xml" title="Blog" href="/rss.xml" />

    <!-- PWA -->
    <!-- apple-touch-icon: generated by /anglesite:design-interview -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Structured data -->
    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <style is:global>
      @import "../design/tokens.css";
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="h-card" data-pagefind-ignore>
      <a href="/" class="p-name u-url">{siteName}</a>
    </header>

    <main id="main" data-pagefind-body>
      <slot />
    </main>

    <footer data-pagefind-ignore>
      <p>
        Authored by <a href="https://dwk.io" rel="me author">David W. Keith</a>.
        Code <a href="https://opensource.org/license/isc-license-txt" rel="external license">ISC</a>;
        spec text and schemas <a href="https://creativecommons.org/public-domain/cc0/" rel="external license">CC0</a>.
      </p>
    </footer>
  </body>
</html>
