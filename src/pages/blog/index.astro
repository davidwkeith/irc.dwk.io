---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const recentPosts = allPosts
  .filter((post) => post.data.publishDate >= thirtyDaysAgo)
  .sort(
    (a, b) =>
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );

const hasOlderPosts = allPosts.some(
  (post) => post.data.publishDate < thirtyDaysAgo,
);
---

<BaseLayout title="Blog" description="Latest news and updates.">
  <h1>Blog</h1>

  {recentPosts.length === 0 && <p>No recent posts. Check back soon!</p>}

  <ul class="post-list">
    {
      recentPosts.map((post) => (
        <li class="h-entry">
          <a href={`/blog/${post.id.replace(/\.mdoc$/, "")}/`} class="u-url">
            <h2 class="p-name">{post.data.title}</h2>
          </a>
          <time
            class="dt-published"
            datetime={post.data.publishDate.toISOString()}
          >
            {post.data.publishDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <p class="p-summary">{post.data.description}</p>
        </li>
      ))
    }
  </ul>

  {hasOlderPosts && <p><a href="/blog/archive/">View older posts</a></p>}
</BaseLayout>
