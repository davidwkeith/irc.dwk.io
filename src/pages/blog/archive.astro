---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const olderPosts = (
  await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
)
  .filter((post) => post.data.publishDate < thirtyDaysAgo)
  .sort(
    (a, b) =>
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );
---

<BaseLayout title="Blog Archive" description="All past posts.">
  <h1>Blog Archive</h1>

  <p><a href="/blog/">&larr; Back to recent posts</a></p>

  {olderPosts.length === 0 && <p>No archived posts yet.</p>}

  <ul class="post-list">
    {
      olderPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id.replace(/\.mdoc$/, "")}/`}>
            <h2>{post.data.title}</h2>
          </a>
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <p>{post.data.description}</p>
        </li>
      ))
    }
  </ul>
</BaseLayout>
